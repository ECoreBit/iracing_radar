                                                                                           "Interpreter":  1,
                                                                                           "Expression":  "return 62 * Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.OverlayOpacity\u0027),92))) / 100*Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.RadarVisualOpacity\u0027),0)))/100;"

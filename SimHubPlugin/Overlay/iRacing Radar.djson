                                                                                           "Expression":  "const p=Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.FrontFarProgress\u0027),0))); const i=Math.max(0,Math.min(59,Math.round(p*59/100))); return isnull($prop(\u0027IRacingRadarPlugin.RadarVisible\u0027),false) \u0026\u0026 isnull($prop(\u0027IRacingRadarPlugin.FrontFarVisible\u0027),false) \u0026\u0026 i==0;"
                                                                                       },
                                                                           "Mode":  2,
                                                                           "TargetPropertyName":  "Visible"
                                                                       },
                                                           "Opacity":  {
                                                                           "Formula":  {

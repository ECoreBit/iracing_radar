                                                                                           "Interpreter":  1,
                                                                                           "Expression":  "const b=100-Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.FrontNearBlend\u0027),0))); const r=Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.FrontProximityOpacity\u0027),0))); const q=50+r*0.5; return b*q/100*Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.OverlayOpacity\u0027),92)))/100*Math.max(0,Math.min(100,isnull($prop(\u0027IRacingRadarPlugin.RadarVisualOpacity\u0027),0)))/100;"
